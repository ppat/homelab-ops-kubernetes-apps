{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "description": "configure version scheme for ppatlabs images",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "ppatlabs/{/,}**"
      ],
      "versioning": "semver-coerced"
    },
    {
      "description": "configure version scheme for linuxserver images",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "ghcr.io/linuxserver/{/,}**"
      ],
      "versioning": "semver-coerced"
    },
    {
      "description": "configure version scheme for plex image",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["plexinc/pms-docker"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\.(?<build>\\d+)-[0-9a-f]+$"
    },
    {
      "description": "configure version scheme for unbound image",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["madnuttah/unbound"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-(?<build>\\d+)$"
    },
    {
      "description": "configure version scheme for minio images",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "minio/minio",
        "minio/mc"
      ],
      "versioning": "regex:^RELEASE\\.(?<major>\\d{4})-(?<minor>\\d{2})-(?<patch>\\d{2})T\\d{2}-\\d{2}-\\d{2}Z$"
    },
    {
      "description": [
        "strip digests from OCIRepository tags (flux rejects digests in ref.tag field)"
      ],
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "ghcr.io/dragonflydb/dragonfly-operator/helm/dragonfly-operator",
        "registry-1.docker.io/bitnamicharts/kubernetes-event-exporter"
      ],
      "matchManagers": [
        "flux"
      ],
      "pinDigests": false
    }
  ]
}
