{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "automerge": false,
      "addLabels": [
        "automerge:off"
      ],
      "description": "disable automerge for specific file paths",
      "matchFileNames": [
        "infrastructure/bootstrap/crds/**"
      ]
    },
    {
      "automerge": false,
      "addLabels": [
        "automerge:off"
      ],
      "description": "disable automerge for openclaw -- unusually high security-advisory volume, every bump gets human review",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "ghcr.io/openclaw/openclaw"
      ]
    }
  ]
}
